#!/bin/bash

# ==============================================================================
#  脚本名称：armbian-apt
#  脚本功能：切换系统软件源，并按需注释 Armbian / armbian-config 源
# ==============================================================================

SOURCE_FILE="/etc/apt/sources.list"
SOURCE_BACKUP_FILE="/etc/apt/sources.list.bak"
DEBIAN_SOURCE_FILE="/etc/apt/sources.list.d/debian.sources"
DEBIAN_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/debian.sources.bak"
UBUNTU_SOURCE_FILE="/etc/apt/sources.list.d/ubuntu.sources"
UBUNTU_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/ubuntu.sources.bak"
ARMBIAN_SOURCE_FILE="/etc/apt/sources.list.d/armbian.sources"
ARMBIAN_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/armbian.sources.bak"
ARMBIAN_CONFIG_SOURCE_FILE="/etc/apt/sources.list.d/armbian-config.sources"
ARMBIAN_CONFIG_SOURCE_BACKUP_FILE="/etc/apt/sources.list.d/armbian-config.sources.bak"
OS_RELEASE_FILE="/etc/os-release"

STEPS="[\033[95m 步骤 \033[0m]"
INFO="[\033[94m 信息 \033[0m]"
SUCCESS="[\033[92m 成功 \033[0m]"
OPTIONS="[\033[93m 选项 \033[0m]"
ERROR="[\033[91m 错误 \033[0m]"
SN="[\033[96m 序号 \033[0m]"

error() {
    echo -e "${ERROR} ${1}"
    exit 1
}

require_command() {
    command -v "${1}" >/dev/null 2>&1 || error "缺少依赖命令：[\033[92m ${1} \033[0m]"
}

check_dependencies() {
    local cmd
    local required_commands=(cp grep id rm sed)

    for cmd in "${required_commands[@]}"; do
        require_command "${cmd}"
    done
}

check_root() {
    [[ "$(id -u)" -eq 0 ]] || error "请使用 root 用户运行！"
}

prompt_yes_no() {
    local prompt="${1}"
    local default="${2:-y}"
    local choice

    read -r -p "$(echo -e "${prompt}")" choice
    choice="${choice:-${default}}"
    [[ "${choice}" =~ ^[Yy]$ ]]
}

load_release_info() {
    [[ -f "${OS_RELEASE_FILE}" ]] || error "未检测到系统的 release 文件！"
    # shellcheck disable=SC1090
    source "${OS_RELEASE_FILE}"

    VERSION_CODEID="${ID}"
    [[ -n "${VERSION_CODEID}" ]] || error "未检测到系统的 VERSION_CODEID！"
    [[ -n "${VERSION_CODENAME}" ]] || error "未检测到系统的 VERSION_CODENAME！"
}

backup_if_needed() {
    local backup_file="${2}"
    local source_file="${1}"

    if [[ -f "${source_file}" && ! -f "${backup_file}" ]]; then
        cp -f "${source_file}" "${backup_file}"
    fi
}

backup_source_list() {
    backup_if_needed "${SOURCE_FILE}" "${SOURCE_BACKUP_FILE}"
    backup_if_needed "${DEBIAN_SOURCE_FILE}" "${DEBIAN_SOURCE_BACKUP_FILE}"
    backup_if_needed "${UBUNTU_SOURCE_FILE}" "${UBUNTU_SOURCE_BACKUP_FILE}"
    backup_if_needed "${ARMBIAN_SOURCE_FILE}" "${ARMBIAN_SOURCE_BACKUP_FILE}"
    backup_if_needed "${ARMBIAN_CONFIG_SOURCE_FILE}" "${ARMBIAN_CONFIG_SOURCE_BACKUP_FILE}"
}

comment_source_file() {
    local file="${1}"

    if [[ -f "${file}" ]]; then
        sed -i 's/^/#/' "${file}"
    fi
}

write_source_list() {
    echo -e "${STEPS} 开始更改系统软件源：[\033[92m ${MIRROR_URL} \033[0m]"
    echo -e "${INFO} 系统版本：[\033[92m ${VERSION_CODENAME} \033[0m]"

    case "${VERSION_CODENAME}" in
        buster)
            cat > "${SOURCE_FILE}" <<EOF
deb http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free

deb http://${MIRROR_URL}/debian ${VERSION_CODENAME}-updates main contrib non-free
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME}-updates main contrib non-free

deb http://${MIRROR_URL}/debian-security ${VERSION_CODENAME}/updates main contrib non-free
#deb-src http://${MIRROR_URL}/debian-security ${VERSION_CODENAME}/updates main contrib non-free
EOF
            ;;
        bullseye)
            cat > "${SOURCE_FILE}" <<EOF
deb http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free

deb http://${MIRROR_URL}/debian ${VERSION_CODENAME}-updates main contrib non-free
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME}-updates main contrib non-free

deb http://${MIRROR_URL}/debian ${VERSION_CODENAME}-backports main contrib non-free
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME}-backports main contrib non-free

deb http://${MIRROR_URL}/debian-security ${VERSION_CODENAME}-security main contrib non-free
#deb-src http://${MIRROR_URL}/debian-security ${VERSION_CODENAME}-security main contrib non-free
EOF
            ;;
        bookworm|trixie|forky)
            cat > "${SOURCE_FILE}" <<EOF
deb http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free non-free-firmware
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free non-free-firmware

deb http://${MIRROR_URL}/debian ${VERSION_CODENAME}-updates main contrib non-free non-free-firmware
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME}-updates main contrib non-free non-free-firmware

deb http://${MIRROR_URL}/debian ${VERSION_CODENAME}-backports main contrib non-free non-free-firmware
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME}-backports main contrib non-free non-free-firmware

deb http://${MIRROR_URL}/debian-security ${VERSION_CODENAME}-security main contrib non-free non-free-firmware
#deb-src http://${MIRROR_URL}/debian-security ${VERSION_CODENAME}-security main contrib non-free non-free-firmware
EOF
            ;;
        focal|jammy|noble|resolute)
            cat > "${SOURCE_FILE}" <<EOF
deb http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME} main restricted universe multiverse
#deb-src http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME} main restricted universe multiverse

deb http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME}-security main restricted universe multiverse
#deb-src http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME}-security main restricted universe multiverse

deb http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME}-updates main restricted universe multiverse
#deb-src http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME}-updates main restricted universe multiverse

deb http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME}-backports main restricted universe multiverse
#deb-src http://${MIRROR_URL}/ubuntu-ports ${VERSION_CODENAME}-backports main restricted universe multiverse
EOF
            ;;
        sid|unstable)
            cat > "${SOURCE_FILE}" <<EOF
deb http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free non-free-firmware
#deb-src http://${MIRROR_URL}/debian ${VERSION_CODENAME} main contrib non-free non-free-firmware
EOF
            ;;
        *)
            error "未检测到系统版本：[ ${VERSION_CODENAME} ]"
            ;;
    esac
}

change_source_list() {
    write_source_list

    if [[ -f "${DEBIAN_SOURCE_FILE}" ]]; then
        if ! grep -q '^[^#]' "${DEBIAN_SOURCE_FILE}"; then
            echo -e "${SUCCESS} 成功更改系统软件源！"
            return 0
        fi
        comment_source_file "${DEBIAN_SOURCE_FILE}"
    fi

    if [[ -f "${UBUNTU_SOURCE_FILE}" ]]; then
        if ! grep -q '^[^#]' "${UBUNTU_SOURCE_FILE}"; then
            echo -e "${SUCCESS} 成功更改系统软件源！"
            return 0
        fi
        comment_source_file "${UBUNTU_SOURCE_FILE}"
    fi

    echo -e "${SUCCESS} 成功更改系统软件源！"
}

restore_default_sources() {
    if [[ -f "${SOURCE_BACKUP_FILE}" ]]; then
        cp -f "${SOURCE_BACKUP_FILE}" "${SOURCE_FILE}"
        if [[ ! -f "${DEBIAN_SOURCE_BACKUP_FILE}" && ! -f "${UBUNTU_SOURCE_BACKUP_FILE}" ]]; then
            echo -e "${SUCCESS} 成功恢复 [\033[92m ${VERSION_CODENAME} \033[0m] 默认源！"
        fi
    fi

    if [[ -f "${DEBIAN_SOURCE_BACKUP_FILE}" ]]; then
        cp -f "${DEBIAN_SOURCE_BACKUP_FILE}" "${DEBIAN_SOURCE_FILE}"
        rm -f "${SOURCE_BACKUP_FILE}" "${SOURCE_FILE}"
        echo -e "${SUCCESS} 成功恢复 [\033[92m ${VERSION_CODENAME} \033[0m] 默认源！"
    fi

    if [[ -f "${UBUNTU_SOURCE_BACKUP_FILE}" ]]; then
        cp -f "${UBUNTU_SOURCE_BACKUP_FILE}" "${UBUNTU_SOURCE_FILE}"
        rm -f "${SOURCE_BACKUP_FILE}" "${SOURCE_FILE}"
        echo -e "${SUCCESS} 成功恢复 [\033[92m ${VERSION_CODENAME} \033[0m] 默认源！"
    fi

    if [[ -f "${ARMBIAN_SOURCE_BACKUP_FILE}" ]]; then
        if prompt_yes_no "${OPTIONS} 是否恢复 armbian 默认源？[\033[92mY\033[0m/n]: " "y"; then
            cp -f "${ARMBIAN_SOURCE_BACKUP_FILE}" "${ARMBIAN_SOURCE_FILE}"
            echo -e "${SUCCESS} 成功恢复 [\033[92m armbian \033[0m] 默认源！"
        else
            echo -e "${INFO} 跳过恢复 armbian 默认源！"
        fi
    fi

    if [[ -f "${ARMBIAN_CONFIG_SOURCE_BACKUP_FILE}" ]]; then
        if prompt_yes_no "${OPTIONS} 是否恢复 armbian-config 默认源？[\033[92mY\033[0m/n]: " "y"; then
            cp -f "${ARMBIAN_CONFIG_SOURCE_BACKUP_FILE}" "${ARMBIAN_CONFIG_SOURCE_FILE}"
            echo -e "${SUCCESS} 成功恢复 [\033[92m armbian-config \033[0m] 默认源！"
        else
            echo -e "${INFO} 跳过恢复 armbian-config 默认源！"
        fi
    fi

    exit 0
}

select_mirror_site() {
    local source_id="${1}"

    echo -e "${INFO} 您选择的源对应序号：[\033[92m ${source_id} \033[0m]"

    case "${source_id}" in
        0)
            restore_default_sources
            ;;
        1)
            MIRROR_URL="mirrors.cernet.edu.cn"
            ;;
        2)
            MIRROR_URL="mirrors.ustc.edu.cn"
            ;;
        3)
            MIRROR_URL="mirrors.bfsu.edu.cn"
            ;;
        4)
            MIRROR_URL="mirrors.tuna.tsinghua.edu.cn"
            ;;
        5)
            MIRROR_URL="mirrors.aliyun.com"
            ;;
    esac

    change_source_list
}

system_source_manage() {
    local source_id

    echo -e "${INFO} 请选择适用于 [\033[92m ${VERSION_CODENAME} \033[0m] 的镜像软件源！"
    echo -e "${SN} [\033[96m 0 \033[0m] -> [\033[92m 恢复默认软件源 \033[0m]"
    echo -e "${SN} [\033[96m 1 \033[0m] -> [\033[92m 高校联合•自动选择 \033[0m]"
    echo -e "${SN} [\033[96m 2 \033[0m] -> [\033[92m 中国科学技术大学 \033[0m]"
    echo -e "${SN} [\033[96m 3 \033[0m] -> [\033[92m 北京外国语大学 \033[0m]"
    echo -e "${SN} [\033[96m 4 \033[0m] -> [\033[92m 清华大学 \033[0m]"
    echo -e "${SN} [\033[96m 5 \033[0m] -> [\033[92m 阿里云 \033[0m]"
    echo -e "${SN} [\033[96m 6 \033[0m] -> [\033[92m 退出 \033[0m]"

    while true; do
        read -r -p "$(echo -ne "${OPTIONS} 请输入序号 [\033[96m 0-6 \033[0m] [ 回车默认 \033[96m1\033[0m ]：")" source_id
        source_id="${source_id:-1}"

        if [[ "${source_id}" =~ ^[0-9]+$ && "${source_id}" -ge 0 && "${source_id}" -le 6 ]]; then
            if [[ "${source_id}" -eq 6 ]]; then
                echo -e "${INFO} 已退出选择！"
                exit 0
            fi
            select_mirror_site "${source_id}"
            break
        fi

        echo -e "${ERROR} 无效选择，重新输入！"
    done
}

disable_source_file() {
    local label="${1}"
    local source_file="${2}"
    local choice

    [[ -f "${source_file}" ]] || error "未找到 ${label} 源文件：${source_file}"

    read -r -p "$(echo -ne "${OPTIONS} 是否注释 ${label} 源？[\033[92mY\033[0m/n]：")" choice
    case "${choice}" in
        [nN])
            echo -e "${INFO} 保持当前状态，不进行注释！"
            ;;
        *)
            if ! grep -q '^[^#]' "${source_file}"; then
                echo -e "${INFO} ${label} 源已注释，无需修改！"
                return 0
            fi
            sed -i 's/^[^#]/#&/' "${source_file}"
            echo -e "${SUCCESS} 成功注释 [\033[92m ${label} \033[0m] 源！"
            ;;
    esac
}

main() {
    check_dependencies
    check_root
    load_release_info
    backup_source_list
    system_source_manage
    disable_source_file "armbian" "${ARMBIAN_SOURCE_FILE}"
    disable_source_file "armbian-config" "${ARMBIAN_CONFIG_SOURCE_FILE}"
}

main "$@"
